{
  "info": {
    "_postman_id": "foodorder-producer-api",
    "name": "FoodOrder Producer API",
    "description": "Collection for FoodOrder.Producer API - AWS SNS Food Order Publishing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Food Order",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Set variables for the request",
              "pm.variables.set('api_key', 'dev-api-key-12345');",
              "pm.variables.set('api_url', 'http://localhost:5000');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Test the response",
              "pm.test('Status code is 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response has required fields', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('orderId');",
              "    pm.expect(jsonData).to.have.property('messageId');",
              "    pm.expect(jsonData).to.have.property('status');",
              "    pm.expect(jsonData).to.have.property('createdAt');",
              "});",
              "",
              "pm.test('Message status is correct', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.equal('Order received and published to SNS');",
              "});",
              "",
              "// Save orderId for later use",
              "pm.test('Save orderId to environment', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.environment.set('last_order_id', jsonData.orderId);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{api_key}}",
            "type": "text",
            "description": "API Key for authentication"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerName\": \"John Doe\",\n  \"customerEmail\": \"john.doe@example.com\",\n  \"deliveryAddress\": \"123 Main Street, New York, NY 10001\",\n  \"items\": [\n    {\n      \"itemName\": \"Margherita Pizza\",\n      \"quantity\": 2,\n      \"price\": 15.99\n    },\n    {\n      \"itemName\": \"Caesar Salad\",\n      \"quantity\": 1,\n      \"price\": 8.99\n    },\n    {\n      \"itemName\": \"Garlic Bread\",\n      \"quantity\": 1,\n      \"price\": 4.99\n    }\n  ],\n  \"totalAmount\": 45.96,\n  \"messageAttributes\": {\n    \"ShopId\": [\"shop-1\"]\n  }\n}"
        },
        "url": {
          "raw": "{{api_url}}/api/foodorder",
          "protocol": "http",
          "host": [
            "{{api_url}}"
          ],
          "path": [
            "api",
            "foodorder"
          ]
        },
        "description": "Creates a new food delivery order and publishes it to AWS SNS"
      }
    },
